//top scroll
var scorllflag = true;

function getSceneOffsetTop(scene) {
	if($(scene).offset() == null) {
		return 0;
	} else {
		return $(scene).offset().top;
	}
}
 
$(function() {
	$('.btn').click(function() {
		scorllflag = false;
		$('body, html').animate({ scrollTop: (getSceneOffsetTop($($(this).attr("href"))) - 90 ) }, "normal",setScrollFlagTrue);
		$('.btn').removeClass("on");
		$(this).addClass("on");

		return false;		
		
	});	
	
	$('.home').click(function() {
		scorllflag = false;
		$('body, html').animate({ scrollTop: (getSceneOffsetTop($($(this).attr("href"))) - 0 ) }, "normal",setScrollFlagTrue);		
			
		return false;
	});	
});
function setScrollFlagTrue() {
	scorllflag = true;
}

//즐겨찾기 추가
function addbookmark(){
	
	var url = "http://taeilcnt.co.kr";
	var title = "태일CNT";
	var browser = navigator.userAgent.toLowerCase();

	//Mozilla, Firefox, Netcape
	/*
	if(window.sidebar){
		window.sidebar.addPanel(title, url, "");
		//alert('test');
	}
*/
	//IE or Chrome
	//else if(window.external){
	if(window.external){
		//IE
		if(browser.indexOf('chrome')==-1){
			window.external.AddFavorite(url, title);
		}else {
		//Chrome
			alert('CTRL+D 또는 Command+D를 눌러 즐겨찾기에 추가해주세요.');
		}
	}
	//Opera - automatically adds to sidebar if rel=sidebar in the tag
	else if(window.opera && window.print){
		return true;
	}
	//Konqueror
	else if(browser.indexOf('konqueror')!=-1){
		alert('CTRL+B를 눌러 즐겨차기에 추가해주세요.');
	}
	//safari
	else if(browser.indexOf('webkit')!=-1){
		alert('CTRL+B 또는 Commnad+B를 눌러 즐겨찾기에 추가해주세요.');
	}else {
		alert('사용하고 계시는 브라우져에서는 이 버튼으로 즐겨찾기를 추가할 수없습니다. 수동으로 링크를 추가해 주세요.');
	}

}


