//팝업창
function popupOpen(_url,_width,_height,_scbar,_left,_top,_center){
	var sw=screen.availWidth;
	var sh=screen.availHeight;
	if(_center=="center") {
	var px = (sw-_width)/2;
	var py = (sh-_height)/2;
	} else {
		var px = _left;
		var py = _top;
	}
	var popUrl = _url;
	var popOption = "width="+_width+", height="+_height+", left="+px+", top="+py+", resizable=no, scrollbars="+_scbar+", status=no;"; 
	window.open(popUrl,"",popOption);
}


